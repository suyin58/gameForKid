{
  "name": "kidsgame-server",
  "version": "1.0.0",
  "description": "儿童AI游戏创作平台 - 后端服务",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:init": "node src/scripts/init-sqljs.js",
    "db:seed": "node src/scripts/seed-sqljs.js",
    "db:init:pg": "node src/scripts/init-db.js",
    "db:seed:pg": "node src/scripts/seed-pg.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright test --reporter=html",
    "test:e2e:show": "playwright show-report",
    "test:ai": "node src/scripts/test-ai.js"
  },
  "keywords": [
    "game",
    "ai",
    "wechat",
    "miniprogram"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.2",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.20.1",
    "pg": "^8.11.3",
    "redis": "^4.6.11",
    "sql.js": "^1.14.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
