# ========================================
# 生产环境配置模板
# ========================================
# 使用方法：
# 1. 复制此文件为 .env
# 2. 修改敏感信息（密钥、密码等）
# 3. 运行 docker-compose up -d
# ========================================

# 应用配置
NODE_ENV=production
PORT=3001

# 数据库配置
DB_TYPE=sqlite
# 如果使用MongoDB，取消下面的注释
# MONGODB_URI=mongodb://admin:password@mongodb:27017/kidsgame?authSource=admin

# JWT密钥（生产环境务必修改！）
JWT_SECRET=kidsgame-production-secret-change-me-immediately

# AI服务配置
OPENAI_API_KEY=your-zhipu-api-key-here
OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
OPENAI_MODEL=glm-4-plus

# 微信小程序配置
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret

# 服务器配置
SERVER_HOST=0.0.0.0
SERVER_PORT=3001

# 日志配置
LOG_LEVEL=info
LOG_FILE_PATH=./logs

# CORS配置（生产环境建议设置具体域名）
CORS_ORIGIN=https://yourdomain.com

# 文件上传配置
UPLOAD_MAX_SIZE=10MB
UPLOAD_ALLOWED_TYPES=.jpg,.jpeg,.png,.gif

# 限流配置
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# 缓存配置（如果使用Redis）
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_PASSWORD=your-redis-password

# 备份配置
BACKUP_ENABLED=true
BACKUP_INTERVAL=86400
BACKUP_RETENTION_DAYS=7
