# 服务器配置
NODE_ENV=development
PORT=3001

# 数据库配置
DB_TYPE=postgresql  # 可选: mongodb, postgresql

# PostgreSQL配置
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=kidsgame
PG_USER=postgres
PG_PASSWORD=your-postgres-password

# MongoDB配置（如果使用MongoDB）
MONGODB_URI=mongodb://localhost:27017/kidsgame

# JWT配置
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=30d

# 微信小程序配置
WECHAT_APPID=your-wechat-appid
WECHAT_SECRET=your-wechat-secret

# OpenAI配置（或Claude）
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4

# Redis配置（可选）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# 腾讯云COS配置（可选）
COS_SECRET_ID=your-cos-secret-id
COS_SECRET_KEY=your-cos-secret-key
COS_BUCKET=your-bucket
COS_REGION=ap-guangzhou

# 日志配置
LOG_LEVEL=info
LOG_FILE_PATH=logs
