# 服务器配置
NODE_ENV=development
PORT=3001

# 数据库配置
DB_TYPE=sqlite

# SQLite配置（无需额外配置，自动使用）
# 数据库文件路径: data/kidsgame.db

# JWT配置
JWT_SECRET=kidsgame-secret-key-development-only
JWT_EXPIRES_IN=30d

# 微信小程序配置（开发环境暂时使用测试值）
WECHAT_APPID=
WECHAT_SECRET=

# OpenAI配置
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4

# 日志配置
LOG_LEVEL=debug
LOG_FILE_PATH=logs
